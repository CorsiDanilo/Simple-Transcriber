<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Tema base Material3 / AppCompat dell'app.
        Usato di default per tutti i componenti non-Activity.
    -->
    <!--
        Theme base dell'app. Usa un tema nativo dell'SDK Android per evitare
        dipendenze esterne (es. com.google.android.material).
        Il look visivo reale è interamente gestito da Compose + MaterialTheme.
    -->
    <style name="Theme.SimpleTranscriberApp" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        Tema trasparente per la MainActivity.
        - windowIsTranslucent: rende l'Activity trasparente (si vede l'app sotto)
        - windowBackground: sfondo completamente trasparente
        - windowNoTitle: nasconde la ActionBar/TitleBar di sistema
        - android:windowIsFloating: evita che l'activity occupi tutto lo schermo nel task switcher
        La Card di Compose (con sfondo semi-trasparente) si occuperà del look visivo.
    -->
    <style name="Theme.SimpleTranscriberApp.Translucent" parent="Theme.SimpleTranscriberApp">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

</resources>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permesso di rete per chiamare le API di Gemini -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- AICore: on-device AI (opzionale, non richiesto) -->
    <uses-feature android:name="com.google.android.aicore" android:required="false" />

    <!-- Consente di verificare se il pacchetto AICore è installato (Android 11+) -->
    <queries>
        <package android:name="com.google.android.aicore" />
    </queries>

    <application
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Transcriber"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        android:localeConfig="@xml/locales_config">

        <!--
            MainActivity configurata con tema trasparente e senza barra del titolo.
            - android:theme: usa il tema translucent definito in themes.xml
            - android:exported="true": richiesto per ricevere intent dall'esterno
            - android:excludeFromRecents="true": l'Activity non compare nei recenti
            - android:taskAffinity="": crea un task separato, non si mescola con l'app condividente
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Transcriber"
            android:excludeFromRecents="false"
            android:taskAffinity=""
            android:launchMode="singleTask">

            <!--
                Intent filter per catturare file audio condivisi.
                Supporta sia audio/* (formati standard come m4a, mp3, wav)
                che application/ogg (nota vocale di WhatsApp su alcuni dispositivi).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>

            <!-- Consente all'app di apparire nel launcher per accedere a Impostazioni e Cronologia -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <service
            android:name=".TranscriptionService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".updater.DownloadReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- Service for app locales storage compatibility -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>
    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permesso di rete per chiamare le API di Gemini -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- AICore: on-device AI (opzionale, non richiesto) -->
    <uses-feature android:name="com.google.android.aicore" android:required="false" />

    <!-- Consente di verificare se il pacchetto AICore è installato (Android 11+) -->
    <queries>
        <package android:name="com.google.android.aicore" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleTranscriberApp"
        android:largeHeap="true">

        <!--
            MainActivity configurata con tema trasparente e senza barra del titolo.
            - android:theme: usa il tema translucent definito in themes.xml
            - android:exported="true": richiesto per ricevere intent dall'esterno
            - android:excludeFromRecents="true": l'Activity non compare nei recenti
            - android:taskAffinity="": crea un task separato, non si mescola con l'app condividente
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SimpleTranscriberApp"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask">

            <!--
                Intent filter per catturare file audio condivisi.
                Supporta sia audio/* (formati standard come m4a, mp3, wav)
                che application/ogg (nota vocale di WhatsApp su alcuni dispositivi).
            -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/ogg" />
            </intent-filter>

            <!-- Consente all'app di apparire nel launcher per accedere a Impostazioni e Cronologia -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>
